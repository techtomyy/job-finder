import { FileText, Download, Edit3 } from "lucide-react";
import { Button } from "@/components/ui/button";
import { useToast } from "@/hooks/use-toast";
import { formatDistanceToNow } from "date-fns";

interface Resume {
  id: string;
  title: string;
  atsScore?: number;
  createdAt: string;
}

interface RecentResumesProps {
  resumes: Resume[];
  onResumeSelect: (resumeId: string) => void;
}

export default function RecentResumes({ resumes, onResumeSelect }: RecentResumesProps) {
  const { toast } = useToast();

  const handleDownload = async (resumeId: string, title: string) => {
    try {
      // Mock download - create a simple text file
      const content = `Mock Resume Content for ${title}\n\nThis is a sample resume content that would normally be generated by the AI.\n\nSkills: React, TypeScript, Node.js\nExperience: 5+ years in software development\nEducation: Bachelor's in Computer Science`;
      
      const blob = new Blob([content], { type: 'text/plain' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.style.display = 'none';
      a.href = url;
      a.download = `${title}.txt`;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      document.body.removeChild(a);

      toast({
        title: "Download started",
        description: "Your resume is being downloaded.",
      });
    } catch (error) {
      toast({
        title: "Download failed",
        description: "Failed to download resume. Please try again.",
        variant: "destructive",
      });
    }
  };

  const getScoreColor = (score?: number) => {
    if (!score) return "text-gray-400";
    if (score >= 90) return "text-success";
    if (score >= 75) return "text-warning";
    return "text-destructive";
  };

  const getScoreBgColor = (score?: number) => {
    if (!score) return "bg-gray-100 dark:bg-gray-700";
    if (score >= 90) return "bg-green-100 dark:bg-green-900/30";
    if (score >= 75) return "bg-yellow-100 dark:bg-green-900/30";
    return "bg-blue-100 dark:bg-blue-900/30";
  };

  return (
    <div className="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700" data-testid="recent-resumes">
      <div className="flex items-center justify-between mb-4">
        <h3 className="text-lg font-semibold text-gray-900 dark:text-white">Recent Resumes</h3>
        <button className="text-sm text-primary hover:text-blue-700 font-medium">
          View All
        </button>
      </div>
      
      <div className="space-y-3">
        {resumes.length === 0 ? (
          <div className="text-center py-8">
            <FileText className="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" />
            <p className="text-gray-500 dark:text-gray-400">No resumes uploaded yet</p>
            <p className="text-sm text-gray-400 dark:text-gray-500">Upload your first resume to get started</p>
          </div>
        ) : (
          resumes.map((resume, index) => (
            <div 
              key={resume.id}
              className="flex items-center space-x-3 p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors cursor-pointer"
              onClick={() => onResumeSelect(resume.id)}
              data-testid={`resume-item-${index}`}
            >
              <div className={`w-10 h-10 ${getScoreBgColor(resume.atsScore)} rounded-lg flex items-center justify-center`}>
                <FileText className={`w-5 h-5 ${resume.atsScore ? getScoreColor(resume.atsScore) : 'text-primary'}`} />
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-sm font-medium text-gray-900 dark:text-white truncate" data-testid={`resume-title-${index}`}>
                  {resume.title}
                </p>
                <p className="text-xs text-gray-500 dark:text-gray-400" data-testid={`resume-meta-${index}`}>
                  {formatDistanceToNow(new Date(resume.createdAt), { addSuffix: true })}
                  {resume.atsScore && ` • ${resume.atsScore}% ATS score`}
                </p>
              </div>
              <div className="flex space-x-1">
                <Button
                  size="sm"
                  variant="ghost"
                  className="p-1 h-auto"
                  onClick={(e) => {
                    e.stopPropagation();
                    handleDownload(resume.id, resume.title);
                  }}
                  data-testid={`download-resume-${index}`}
                >
                  <Download className="w-4 h-4" />
                </Button>
                <Button
                  size="sm"
                  variant="ghost"
                  className="p-1 h-auto"
                  onClick={(e) => {
                    e.stopPropagation();
                    // Handle edit action
                    toast({
                      title: "Edit feature",
                      description: "Edit functionality would be implemented here.",
                    });
                  }}
                  data-testid={`edit-resume-${index}`}
                >
                  <Edit3 className="w-4 h-4" />
                </Button>
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  );
}
